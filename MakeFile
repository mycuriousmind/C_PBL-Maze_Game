# Makefile
# --------
# Automates compiling for both native Windows and Emscripten (web).
#
# Usage:
#   make native    — build native Windows .exe
#   make web       — build Emscripten .html/.js/.wasm
#   make all       — build both
#   make run       — build & launch native exe
#   make serve     — build web & start local server on port 8080
#   make clean     — remove build artifacts

# ---------------------------------------------------------------
# VARIABLES
# ---------------------------------------------------------------

# Source files
SRCS = main.c maze.c astar.c

# Raylib paths (source repo in project)
RAYLIB_SRC = ./raylib/src
RAYLIB_INCLUDE = -I$(RAYLIB_SRC)

# --- Native (gcc) ---
CC = gcc
CFLAGS = -Wall -Wextra -std=c99 -g -pedantic
NATIVE_TARGET = maze_game.exe
NATIVE_LIBS = -L$(RAYLIB_SRC) -lraylib -lgdi32 -lwinmm -lm

# --- Emscripten (emcc) ---
EMCC = emcc
EMCFLAGS = -Os -Wall -DPLATFORM_WEB
WEB_TARGET = index.html
WEB_LIBS = -L$(RAYLIB_SRC) -lraylib_web -s USE_GLFW=3 -s ASYNCIFY
SHELL_FILE = --shell-file $(RAYLIB_SRC)/shell.html

# Uncomment and add audio files when they exist:
# PRELOAD = --preload-file win.wav --preload-file lose.wav

# ---------------------------------------------------------------
# TARGETS
# ---------------------------------------------------------------

all: native web

# --- Native build ---
native: $(NATIVE_TARGET)

$(NATIVE_TARGET): $(SRCS)
	$(CC) $(CFLAGS) $(RAYLIB_INCLUDE) -o $(NATIVE_TARGET) $(SRCS) $(NATIVE_LIBS)
	@echo ""
	@echo "  ✅ Native build successful! Run with: ./$(NATIVE_TARGET)"
	@echo ""

# --- Web build ---
web: $(WEB_TARGET)

$(WEB_TARGET): $(SRCS)
	$(EMCC) $(EMCFLAGS) $(RAYLIB_INCLUDE) -o $(WEB_TARGET) $(SRCS) $(WEB_LIBS) $(SHELL_FILE) $(PRELOAD)
	@echo ""
	@echo "  ✅ Web build successful! Serve with: make serve"
	@echo ""

# --- Utility targets ---
run: native
	./$(NATIVE_TARGET)

serve: web
	python -m http.server 8080

clean:
	rm -f $(NATIVE_TARGET) index.html index.js index.wasm index.data
	rm -f *.o
	@echo "  🧹 Cleaned all build artifacts."

.PHONY: all native web run serve clean